rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Fonte da verdade de "quem é quem" (role/eid por e-mail).
    // Admins podem gravar qualquer entrada. Qualquer outra pessoa só pode
    // CRIAR a própria entrada (pelo e-mail dela) e só como role 'client' —
    // isso é o que permite o formulário público de cadastro (form.html)
    // funcionar sem exigir que um admin cadastre cada cliente manualmente,
    // sem abrir brecha para alguém se autodeclarar admin.
    match /roleAssignments/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow create: if request.auth != null && (
        (request.auth.token.email == email && request.resource.data.role == 'client') ||
        request.auth.token.email in ['tcaetano1706@gmail.com', 'carlos@flowsales.com']
      );
      allow update, delete: if request.auth != null &&
        request.auth.token.email in ['tcaetano1706@gmail.com', 'carlos@flowsales.com'];
    }

    // Perfil por usuário autenticado (uid). Só ele mesmo lê/cria o próprio
    // perfil, e só se role/eid baterem com o roleAssignments dele (evita
    // que alguém se autodeclare admin ou de outro escritório).
    match /userProfiles/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role == get(/databases/$(database)/documents/roleAssignments/$(request.auth.token.email)).data.role
        && request.resource.data.eid  == get(/databases/$(database)/documents/roleAssignments/$(request.auth.token.email)).data.eid;
      allow delete: if false;
    }

    // Config compartilhada (lista de escritórios, usuários dinâmicos legados,
    // overrides de senha em transição). Fica liberada pra qualquer usuário
    // autenticado (inclusive anônimo) — é uma etapa de transição até que
    // todo mundo tenha migrado para o Firebase Auth; depois disso o campo
    // "pass" deixa de existir aqui.
    match /flowsales_crm/__config {
      allow read, write: if request.auth != null;
    }

    // Dados de cada escritório: só o dono (eid bate com o perfil) ou admin.
    // Exceção: CRIAR um escritório novo (doc que ainda não existe) é liberado
    // para qualquer autenticado — é o que o formulário público de cadastro
    // (form.html) usa. Uma vez criado, só dono/admin conseguem ler ou mexer.
    match /flowsales_crm/{eid} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null && (
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.eid == eid ||
        get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin'
      );

      match /files/{fileId} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.eid == eid ||
          get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == 'admin'
        );
      }
    }

    // Este projeto Firebase é compartilhado com o app "Body & Mind"
    // (thiagojoc/bodyandmind), que usa users/thiago sem login nenhum.
    // Mantém o comportamento atual dele (não mexe, não trava, não abre mais
    // do que já estava) — arrumar a segurança desse app é tarefa separada.
    match /users/{userId} {
      allow read, write: if true;
    }

    // Material do workshop (thiagojoc/workshopfs): documento único com as
    // edições ao vivo do texto, sem login (Alinne/Kênia/Carlos abrem o link
    // direto). É conteúdo de copy/material interno, não dado sensível de
    // cliente, então liberar leitura/escrita sem autenticação é aceitável.
    match /workshopfs/{docId} {
      allow read, write: if true;
    }

    // Qualquer outra coisa fora do previsto acima: negado por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
